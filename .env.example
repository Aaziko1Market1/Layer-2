# ============================================================
# Aaziko AI Communicator Agents - Environment Configuration
# 100% Open-Source Edition
# ============================================================

# Tiered Communication Models (OpenAI-compatible)
COMM_PREMIUM_BASE_URL=https://api.siliconflow.cn/v1
COMM_PREMIUM_MODEL=Qwen/Qwen3.5-397B-A17B
COMM_PREMIUM_API_KEY=your_siliconflow_key

COMM_MID_BASE_URL=https://api.siliconflow.cn/v1
COMM_MID_MODEL=Qwen/Qwen3.5-122B-A10B
COMM_MID_API_KEY=your_siliconflow_key

COMM_LOCAL_BASE_URL=http://localhost:11434/v1
COMM_LOCAL_MODEL=qwen3.5:9b

# Buyer Research Model
RESEARCH_BASE_URL=https://api.deepinfra.com/v1/openai
RESEARCH_MODEL=deepseek-ai/DeepSeek-V3
RESEARCH_API_KEY=your_deepinfra_key

# Local Intent Classifier (Ollama)
INTENT_BASE_URL=http://localhost:11434/v1
INTENT_MODEL=qwen3-8b-aaziko:latest

# Compliance
COMPLIANCE_BASE_URL=http://localhost:11434/v1
COMPLIANCE_MODEL=qwen3-14b-compliance:latest
COMPLIANCE_FALLBACK_BASE_URL=https://api.deepinfra.com/v1/openai
COMPLIANCE_FALLBACK_MODEL=Gryphe/MythoMax-L2-13b

# Infrastructure
MONGODB_URI=mongodb://localhost:27017
REDIS_URL=redis://localhost:6379
QDRANT_URL=http://localhost:6333

# Channel APIs
SENDGRID_API_KEY=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Zoho Mail (SMTP + IMAP)
ZOHO_MAIL_EMAIL=your_zoho_email@zohomail.com
ZOHO_MAIL_PASSWORD=your_app_specific_password
ZOHO_SMTP_HOST=smtp.zoho.com
ZOHO_SMTP_PORT=465
ZOHO_IMAP_HOST=imap.zoho.com
ZOHO_IMAP_PORT=993
ZOHO_SENDER_NAME=Arjun
ZOHO_REPLY_TO=

# Auto-Mail Campaign
AUTOMAIL_ENABLED=true
AUTOMAIL_MAX_PER_DAY=100
AUTOMAIL_MAX_PER_HOUR=20
AUTOMAIL_INBOX_POLL_SECONDS=60
AUTOMAIL_WORKING_HOURS_START=9
AUTOMAIL_WORKING_HOURS_END=18
AUTOMAIL_TIMEZONE=Asia/Kolkata
AUTOMAIL_FOLLOWUP_INTERVALS=48,96,168,336

# App
CORS_ORIGIN=*
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Admin
ADMIN_EMAILS=admin@aaziko.com
WEEKLY_DIGEST_ENABLED=true
